# Copy this file to .env and fill in real values. Never commit the real .env file.

# Google Gemini — used for OCR (vision) and the Socratic tutor (chat)
# Get a free key at https://aistudio.google.com/apikey — no credit card needed
GEMINI_API_KEY=AIza...your-gemini-key-here...

# Choose ONE vector DB and fill its section
VECTOR_DB=qdrant                # qdrant | pinecone

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=textbooks

# --- Pinecone (only needed if VECTOR_DB=pinecone) ---
PINECONE_API_KEY=
PINECONE_INDEX=textbooks

# Models
OCR_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=all-MiniLM-L6-v2
SOCRATIC_MODEL=gemini-2.5-flash

# Service
SERVICE_PORT=8000
