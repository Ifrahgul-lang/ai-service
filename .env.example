
GROQ_API_KEY=your_new_groq_key_here

# Choose ONE vector DB and fill its section
VECTOR_DB=qdrant                # qdrant | pinecone

# --- Qdrant ---
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=textbooks

# --- Pinecone (only needed if VECTOR_DB=pinecone) ---
PINECONE_API_KEY=
PINECONE_INDEX=textbooks

# Models
OCR_MODEL=llama-3.2-11b-vision-preview
EMBEDDING_MODEL=all-MiniLM-L6-v2
SOCRATIC_MODEL=openai/gpt-oss-120b

# Service
SERVICE_PORT=8000
